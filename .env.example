# --- Telegram ---
# Токен бота из @BotFather
TELEGRAM_BOT_TOKEN=
# Список разрешённых Telegram user_id через запятую (узнать у @userinfobot).
# Если пусто — бот никого не пустит (fail-closed).
TELEGRAM_ALLOWED_USER_IDS=

# --- Telegram network / proxy (опционально) ---
# Таймауты HTTP-запросов к Telegram API, в секундах. Значения по умолчанию — 30.
# TELEGRAM_CONNECT_TIMEOUT=30
# TELEGRAM_READ_TIMEOUT=30
# TELEGRAM_WRITE_TIMEOUT=30
# TELEGRAM_POOL_TIMEOUT=30
# Прокси на случай, если VPS не имеет прямого доступа к api.telegram.org.
# Поддерживаются схемы: http://, https://, socks5://, socks5h://
# (socks-зависимости уже включены в requirements.txt).
# Пример: socks5://user:pass@proxy.example.com:1080
# TELEGRAM_PROXY_URL=
# По умолчанию тот же прокси используется и для get_updates (long polling).
# При необходимости можно указать отдельно:
# TELEGRAM_GET_UPDATES_PROXY_URL=
# Задержка между попытками перезапуска при сетевой ошибке старта (секунды).
# TELEGRAM_STARTUP_RETRY_DELAY=15

# --- OpenRouter (vision) ---
# Получить ключ на https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Модель с поддержкой vision, напр. openai/gpt-4o-mini, anthropic/claude-3.5-sonnet,
# google/gemini-2.0-flash-001 и т.п. См. https://openrouter.ai/models
OPENROUTER_MODEL=
# Обычно менять не нужно
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- my_endpoints contacts API ---
# Базовый URL сервиса, напр. https://ct.bshkv.ru
MY_ENDPOINTS_API_BASE_URL=
# Необязательный Bearer-токен, если API требует авторизацию
MY_ENDPOINTS_BEARER_TOKEN=

# Таймаут HTTP-запросов в секундах
HTTP_TIMEOUT=60
