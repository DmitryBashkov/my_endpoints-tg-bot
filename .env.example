# --- Telegram ---
# Токен бота из @BotFather
TELEGRAM_BOT_TOKEN=
# Список разрешённых Telegram user_id через запятую (узнать у @userinfobot).
# Если пусто — бот никого не пустит (fail-closed).
TELEGRAM_ALLOWED_USER_IDS=

# --- OpenRouter (vision) ---
# Получить ключ на https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Модель с поддержкой vision, напр. openai/gpt-4o-mini, anthropic/claude-3.5-sonnet,
# google/gemini-2.0-flash-001 и т.п. См. https://openrouter.ai/models
OPENROUTER_MODEL=
# Обычно менять не нужно
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- my_endpoints contacts API ---
# Базовый URL сервиса, напр. https://ct.bshkv.ru
MY_ENDPOINTS_API_BASE_URL=
# Необязательный Bearer-токен, если API требует авторизацию
MY_ENDPOINTS_BEARER_TOKEN=

# Таймаут HTTP-запросов в секундах
HTTP_TIMEOUT=60
